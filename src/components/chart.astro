---
// 接收來自 [year].astro 傳入的年份
const { currentYear: yearProp } = Astro.props;
---

<div id="chart-container-root" data-year={yearProp}>
    <div class="carousel-container">
        <button class="arrow prev" id="prevMonth">&#10094;</button>
        <div id="chart"></div>
        <button class="arrow next" id="nextMonth">&#10095;</button>
    </div>
    <div class="dots" id="dot-container"></div>
</div>

<script is:inline>
    const root = document.getElementById('chart-container-root');
    const currentYear = root.dataset.year;
    const basePath = '/earth-science-explore'; 

    let currentIdx = 0;
    let months = Array.from({length: 12}, (_, i) => `${currentYear}-${String(i + 1).padStart(2, '0')}`);
    let isProcessing = false;
        const featureDescriptions = {
        // 2021 反聖嬰特徵描述
        //待更改
        "2021-01": "反聖嬰現象強盛，雖然有冬季冷高壓，但台灣東側海域仍可見明顯正距平。",
        "2021-02": "暖水持續在台灣南部與東部海域盤據，顯示西太平洋熱含量豐富。",
        "2021-03": "春季開始，台灣海峽暖化跡象明顯，溫度異常範圍擴大。",
        "2021-04": "正距平訊號（紅色）轉趨強烈，顯示反聖嬰背景下的海洋蓄熱效應。",
        "2021-05": "梅雨季前夕，周邊海域溫度普遍偏高，可能增加水氣輸送。",
        "2021-06": "進入夏季，全海域呈現大面積紅色，距平值達 +1.0°C 以上。",
        "2021-07": "高溫範圍穩定，黑潮路徑上的異常暖水非常顯著。",
        "2021-08": "海溫異常達到夏季高峰，台灣周邊幾乎被暖水包圍。",
        "2021-09": "秋季開始，但反聖嬰導致的暖化訊號未見消退。",
        "2021-10": "雖然大氣轉涼，但海洋對溫度的反應較慢，維持暖色調。",
        "2021-11": "台灣海域依然偏暖，與典型冷冬的大氣感官形成對比。",
        "2021-12": "年底維持溫和正距平，顯示該年海洋熱量輸出極為穩定。",
        // 2023 聖嬰特徵描述
        "2023-01": "延續前兩年反聖嬰餘波，台灣附近仍有微弱正距平，但範圍開始縮小。",
        "2023-02": "海溫距平開始轉趨中性，紅色區塊逐漸被白色（正常）取代。",
        "2023-03": "聖嬰訊號開始醞釀，台灣周邊出現局部負距平（藍色），顯示熱量外移。",
        "2023-04": " 海溫波動劇烈，海峽訊號偏弱，整體處於氣候轉折期。",
        "2023-05": "聖嬰現象正式成形，台灣附近熱量堆積速度減緩，顏色偏淡。",
        "2023-06": "進入夏季，受全球海洋熱浪影響，距平值再度轉正。",  
        "2023-07": "聖嬰事件確立，台灣南部海域熱量累積速度加快，呈現粉紅色。",
        "2023-08": "高溫訊號明顯，聖嬰年的「暖池偏移」效應在此時與夏季高溫疊加。",
        "2023-09": "異常升溫持續，黑潮主流區顏色加深，距平值接近 +1.5°C。",
        "2023-10": "聖嬰強盛期，台灣海溫未如往年秋季迅速轉冷，維持顯著暖意。",
        "2023-11": "聖嬰達到巔峰，台灣周邊海域呈現強烈紅橘色，異常升溫極為明顯。",
        "2023-12": "年底受聖嬰現象與全球暖化雙重影響，出現明顯「暖冬」海洋訊號。",
