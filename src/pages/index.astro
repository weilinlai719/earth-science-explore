---
// src/pages/index.astro
import MainLayout from '../layout/mainlayout.astro';
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
return Astro.redirect('/earth-science-explore/year/2021');
---
<MainLayout>
    <div class="main-container">
        <div class="dashboard">
            <Header/>
            <h1>聖嬰/反聖嬰事件：台灣周邊海溫異常分佈</h1>
            <chart />
        </div>
        
        <div class="dashboarder">
            <div class="type-tab">
                <button class="taber-btn active">特徵分析</button>
                <button class="taber-btn">AI解說</button>
            </div>
            <div class="info-section">
                <div class="month-tag" id="month-label">載入中...</div>
                <p id="feature-text">正在載入數據...</p>
            </div>
        </div>
    </div>
    <Footer />
</MainLayout>