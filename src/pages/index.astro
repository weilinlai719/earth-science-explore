---
// src/pages/index.astro
import MainLayout from '../layout/mainlayout.astro';
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
---
<html lang="zh-Hant">
<meta charset="utf-8" /> 
<head>
    <title>地球科學探索:home</title>
    <script>
        const num = Math.floor(Math.random() * 3) + 1;
        if (num === 1||num === 2) {
            window.location.href = "/earth-science-explore/year/2021/";
        }
    </script>

</head>
<MainLayout>
    <Header/>
    <div class="main-container">
        <div class="bashboard" >
            <h1 style="text-align: center;">聖嬰/反聖嬰事件：台灣周邊海溫異常分佈</h1>
            <p>歡迎來到地球科學探索！這裡將帶你深入了解聖嬰 / 反聖嬰事件對台灣周邊海溫異常分佈的影響。透過互動式圖表和詳細分析，我們將揭示這些氣候現象如何改變我們的環境，並探討未來可能的趨勢。</p>
            <p style="font-size: 1.6rem;">請點擊上方選單中的年份，查看各年度的海溫異常分析。</p>
        </div>
    </div>
    <Footer />
</MainLayout>
</html>
