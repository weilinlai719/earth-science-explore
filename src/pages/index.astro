---
// src/pages/index.astro
import MainLayout from '../layout/mainlayout.astro';
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
return Astro.redirect('/earth-science-explore/year/2021');
---
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
  <meta http-equiv="refresh" content="0;url=/earth-science-explore/year/2021/" />
    <script is:inline>
        // 使用 JS 立即跳轉，這比 meta refresh 快
        window.location.pathname = '/earth-science-explore/year/2021/';
    </script>
</head>

<MainLayout>
    <div class="main-container">
        <div class="dashboard">
            <Header/>
            <h1>聖嬰/反聖嬰事件：台灣周邊海溫異常分佈</h1>
            <chart />
        </div>
        
        <div class="dashboarder">
            <div class="type-tab">
                <button class="taber-btn active">特徵分析</button>
                <button class="taber-btn">AI解說</button>
            </div>
            <div class="info-section">
                <div class="month-tag" id="month-label">載入中...</div>
                <p id="feature-text">正在載入數據...</p>
            </div>
        </div>
    </div>
    <Footer />
</MainLayout>
</html>